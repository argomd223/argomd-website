<script>
// Device-based routing for Retatrutide links
// Mobile -> selectable medication page
// Desktop -> Tirzepatide-only page (Retatrutide not yet approved)
(function() {
    function isMobile() {
        return /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent) || window.innerWidth < 768;
    }
    window.getRetatrutideUrl = function() {
        return isMobile() ? 'products/retatrutide.html' : 'products/retatrutide-desktop.html';
    };
    // Update retatrutide links on DOM ready
    document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('a[href="products/retatrutide.html"]').forEach(function(link) {
            link.href = window.getRetatrutideUrl();
        });
    });
})();
</script>
